import std.bim.unit;
import std.bim.geometry;

let v = std.bim.geometry.Vector3D;
print("Vector3D: " + str(v));
let p = std.bim.geometry.Point3D;
print("Point3D: " + str(p));
let l = std.bim.geometry.Line3D;
print("Line3D: " + str(l));
let b = std.bim.geometry.BBox3D;
print("BBox3D: " + str(b));
print("OK");