// defer 测试
def write_file_safe(path: String, content: String) {
    let f = path;
    defer {
        print("cleanup: closing file " + f);
    };
    print("writing to " + f);
    write_file(f, content);
    print("write done");
}

write_file_safe("D:\Desktop\worksheet\intent\_test_defer.txt", "hello defer");
print("after call");