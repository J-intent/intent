#!/usr/bin/env python3
"""
Intent语言交互式REPL
"""

import sys
import os
import readline  # 用于命令行历史记录
from typing import Optional, List, Dict, Any

# 导入已有的解释器
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
try:
    from mini_intent import Lexer, Parser, Interpreter, PhilosophyTranslator
except ImportError:
    print("错误: 无法导入mini_intent模块")
    print("请确保在项目根目录运行: python src/repl.py")
    sys.exit(1)

class IntentREPL:
    """Intent语言交互式环境"""
    
    def __init__(self, show_philosophy: bool = False):
        self.interpreter = Interpreter()
        self.translator = PhilosophyTranslator()
        self.show_philosophy = show_philosophy
        self.variables = {}
        self.functions = {}
        self.history = []
        
        # 欢迎信息
        self.print_welcome()
    
    def print_welcome(self):
        """显示欢迎信息"""
        print("""
╔══════════════════════════════════════════╗
║          Intent REPL v0.1.0             ║
║  输入代码执行，.help查看命令，.exit退出  ║
╚══════════════════════════════════════════╝
        """)
        
        if self.show_philosophy:
            print("🧘 当前模式: 哲学视角")
        print("")
    
    def handle_command(self, command: str) -> bool:
        """处理REPL命令，返回True表示继续，False表示退出"""
        cmd = command.strip()
        
        if cmd == ".exit" or cmd == ".quit":
            print("再见！🧘")
            return False
        
        elif cmd == ".help":
            self.show_help()
            return True
        
        elif cmd == ".clear":
            self.variables.clear()
            self.functions.clear()
            print("🧹 已清除所有变量和函数")
            return True
        
        elif cmd == ".vars":
            self.show_variables()
            return True
        
        elif cmd == ".funcs":
            self.show_functions()
            return True
        
        elif cmd == ".history":
            self.show_history()
            return True
        
        elif cmd == ".mode":
            self.show_philosophy = not self.show_philosophy
            mode = "哲学视角" if self.show_philosophy else "普通模式"
            print(f"🔄 切换为: {mode}")
            return True
        
        elif cmd == ".demo":
            self.run_demo()
            return True
        
        elif cmd.startswith(".run "):
            filename = cmd[5:].strip()
            self.run_file(filename)
            return True
        
        else:
            print(f"未知命令: {cmd}")
            print("输入 .help 查看可用命令")
            return True
    
    def show_help(self):
        """显示帮助信息"""
        print("""
📋 REPL命令:
  .help      显示此帮助信息
  .exit      退出REPL
  .quit      同.exit
  .clear     清除所有变量和函数
  .vars      显示当前所有变量
  .funcs     显示当前所有函数
  .history   显示历史命令
  .mode      切换哲学/普通模式
  .demo      运行演示程序
  .run <文件> 运行.intent文件
  
📝 示例代码:
  let x = 10
  let y = 20
  x + y
  
  def add(a, b) { return a + b; }
  add(5, 3)
  
  print("Hello, Intent!")
        """)
    
    def show_variables(self):
        """显示所有变量"""
        if not self.variables:
            print("没有定义变量")
            return
        
        print("📊 当前变量:")
        for name, value in self.variables.items():
            print(f"  {name} = {value} ({type(value).__name__})")
    
    def show_functions(self):
        """显示所有函数"""
        if not self.functions:
            print("没有定义函数")
            return
        
        print("📋 当前函数:")
        for name, func in self.functions.items():
            params = ", ".join([p[0] for p in func.params])
            print(f"  {name}({params})")
    
    def show_history(self):
        """显示命令历史"""
        if not self.history:
            print("没有历史记录")
            return
        
        print("📜 历史记录:")
        for i, cmd in enumerate(self.history[-10:], 1):  # 只显示最近10条
            print(f"  {i:2d}. {cmd}")
    
    def run_demo(self):
        """运行演示程序"""
        demo_code = """
def greet(name) {
    print("你好，", name, "！");
    return "欢迎来到Intent世界";
}

let message = greet("旅行者");
print("消息：", message);
        """
        
        print("🎬 运行演示程序:")
        print("-" * 40)
        self.evaluate(demo_code)
        print("-" * 40)
    
    def run_file(self, filename: str):
        """运行.intent文件"""
        if not os.path.exists(filename):
            print(f"错误: 文件不存在 {filename}")
            return
        
        try:
            with open(filename, 'r', encoding='utf-8') as f:
                code = f.read()
            
            print(f"📁 运行文件: {filename}")
            print("-" * 40)
            self.evaluate(code)
            print("-" * 40)
        except Exception as e:
            print(f"错误: {e}")
    
    def evaluate(self, code: str) -> Any:
        """评估Intent代码"""
        try:
            # 显示哲学视角
            if self.show_philosophy:
                print("🧘 哲学视角:")
                translated = self.translator.translate_code(code)
                print(translated)
                print()
            
            # 词法分析
            lexer = Lexer(code)
            tokens = lexer.tokenize()
            
            # 语法分析
            parser = Parser(tokens)
            ast = parser.parse()
            
            # 提取函数定义
            for func in ast.functions:
                self.functions[func.name] = func
            
            # 查找main函数或执行语句
            result = None
            for func in ast.functions:
                if func.name == 'main':
                    result = self.interpreter.execute_function(func, [])
                    break
            
            # 更新变量
            self.variables.update(self.interpreter.variables)
            
            return result
            
        except Exception as e:
            print(f"❌ 错误: {type(e).__name__}: {e}")
            return None
    
    def evaluate_expression(self, expr: str) -> Any:
        """评估表达式（简化版）"""
        # 包裹在print语句中以便显示结果
        code = f"print({expr});"
        return self.evaluate(code)
    
    def repl_loop(self):
        """REPL主循环"""
        while True:
            try:
                # 读取输入
                try:
                    line = input(">>> ").strip()
                except EOFError:
                    print()  # 换行
                    break
                except KeyboardInterrupt:
                    print()  # 换行
                    print("输入 .exit 退出")
                    continue
                
                # 跳过空行
                if not line:
                    continue
                
                # 添加到历史
                self.history.append(line)
                
                # 处理命令
                if line.startswith('.'):
                    if not self.handle_command(line):
                        break
                    continue
                
                # 评估代码
                result = self.evaluate(line)
                
                # 如果结果是单个表达式，显示结果
                if (result is not None and 
                    not line.startswith('print(') and
                    not line.startswith('def ') and
                    not line.startswith('let ')):
                    print(f"=> {result}")
                
            except Exception as e:
                print(f"错误: {e}")

def main():
    """主函数"""
    import argparse
    
    parser = argparse.ArgumentParser(description='Intent语言REPL')
    parser.add_argument('--philosophy', '-p', action='store_true', help='启用哲学视角')
    parser.add_argument('--file', '-f', help='运行文件后进入REPL')
    
    args = parser.parse_args()
    
    # 创建REPL
    repl = IntentREPL(show_philosophy=args.philosophy)
    
    # 如果有文件，先运行
    if args.file:
        repl.run_file(args.file)
    
    # 进入REPL循环
    repl.repl_loop()

if __name__ == '__main__':
    main()